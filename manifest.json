{
  "manifest_version": 3,
  "name": "Tabbed IDE",
  "version": "1.0.0",
  "description": "Split-screen AI Coding IDE. Chat with Gemini or Perplexity on the left, get syntax-highlighted code on the right. Click the toolbar icon to open.",
  "author": "NerdyGamers",

  "permissions": [
    "cookies",
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "tabs",
    "activeTab"
  ],

  "host_permissions": [
    "*://gemini.google.com/*",
    "*://*.google.com/*",
    "*://perplexity.ai/*",
    "*://www.perplexity.ai/*",
    "*://chatgpt.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_title": "Open Tabbed IDE",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules/dynamic_rules.json"
      }
    ]
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["ide.html", "newtab.css", "newtab.js", "libs/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
